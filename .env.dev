CASHLY_POSTGRES_USER=user
CASHLY_POSTGRES_PASSWORD=Your_Password_123
CASHLY_POSTGRES_DB=cashly_dev

NEXTCLOUD_DB_PASSWORD=Your_Password_123

COUCHDB_OBSIDIAN_USER=user
COUCHDB_OBSIDIAN_PASSWORD=Your_Password_123

# Environment
ASPNETCORE_ENVIRONMENT=Development
NODE_ENV=development

# Domain & TLS
# CERT_RESOLVER vuoto = Traefik usa certificato self-signed automatico
DOMAIN=localhost
CERT_RESOLVER=

# URLs
CASHLY_API_URL=https://localhost/cashly-api
MR_WHITE_API_URL=https://localhost/mr-white-api

# Nextcloud
NEXTCLOUD_DOMAIN=localhost
NEXTCLOUD_PROTOCOL=http
NEXTCLOUD_CLI_URL=http://localhost/cloud
